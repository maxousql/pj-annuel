{
  "name": "@content-ai/api",
  "private": true,
  "version": "0.1.0",
  "description": "Backend NestJS de la plateforme Content AI.",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "scripts": {
    "build": "npm run db:generate && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "node --watch --enable-source-maps -r ts-node/register -r tsconfig-paths/register src/main.ts",
    "start:e2e": "node --enable-source-maps -r ts-node/register -r tsconfig-paths/register src/main.ts",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:status": "prisma migrate status",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "test": "jest --config jest.config.cjs --runInBand",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@content-ai/shared": "0.1.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bcryptjs": "3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "jsonwebtoken": "9.0.3",
    "pg": "8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/express": "5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "^22.10.2",
    "@types/pg": "8.20.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "7.8.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
