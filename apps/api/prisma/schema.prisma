generator client {
  provider               = "prisma-client"
  output                 = "../src/generated/prisma"
  moduleFormat           = "cjs"
  generatedFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE

  @@map("auth_provider")
}

enum OrganizationRole {
  ADMIN
  EDITOR
  READER

  @@map("organization_role")
}

enum MembershipStatus {
  ACTIVE
  PENDING
  DISABLED

  @@map("membership_status")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED

  @@map("invitation_status")
}

enum ContentFormat {
  BLOG_ARTICLE
  LINKEDIN_POST
  SOCIAL_POST
  EMAIL
  HOOK
  THREAD
  OTHER

  @@map("content_format")
}

enum ContentIdeaStatus {
  DRAFT
  SAVED
  DISMISSED
  USED
  ARCHIVED

  @@map("content_idea_status")
}

enum ContentItemStatus {
  DRAFT
  REVIEW
  READY
  SCHEDULED
  PUBLISHED
  ARCHIVED
  DELETED

  @@map("content_item_status")
}

enum ContentSource {
  AI_GENERATED
  USER_CREATED
  CURATED_RESOURCE
  IMPORTED
  NOTION

  @@map("content_source")
}

enum ResourceType {
  URL
  RSS
  MANUAL
  NOTION

  @@map("resource_type")
}

enum ResourceStatus {
  NEW
  SUMMARIZED
  USED
  ARCHIVED

  @@map("resource_status")
}

enum SourceFeedStatus {
  ACTIVE
  PAUSED
  ERROR

  @@map("source_feed_status")
}

enum PublicationChannel {
  LINKEDIN
  BLOG
  EMAIL
  X
  FACEBOOK
  INSTAGRAM
  OTHER

  @@map("publication_channel")
}

enum PublicationStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  CANCELLED

  @@map("publication_status")
}

enum IntegrationProvider {
  NOTION
  GOOGLE
  RSS
  OTHER

  @@map("integration_provider")
}

enum IntegrationStatus {
  ACTIVE
  DISABLED
  ERROR

  @@map("integration_status")
}

enum AiGenerationType {
  IDEA
  CONTENT
  SUMMARY
  DUPLICATE_CHECK
  EDITORIAL_CONTEXT
  CONTENT_IDEA
  CONTENT_DRAFT
  RESOURCE_SUMMARY

  @@map("ai_generation_type")
}

enum AiGenerationStatus {
  SUCCEEDED
  FAILED

  @@map("ai_generation_status")
}

enum AutomationRuleType {
  PUBLICATION_REMINDER
  EDITORIAL_RECOMMENDATION

  @@map("automation_rule_type")
}

enum AutomationRuleStatus {
  ACTIVE
  PAUSED

  @@map("automation_rule_status")
}

enum ReminderStatus {
  PENDING
  SENT
  CANCELLED

  @@map("reminder_status")
}

enum RecommendationStatus {
  OPEN
  DISMISSED
  APPLIED

  @@map("recommendation_status")
}

enum NotificationStatus {
  UNREAD
  READ

  @@map("notification_status")
}

enum NotionSyncEntityType {
  CONTENT
  RESOURCE

  @@map("notion_sync_entity_type")
}

enum NotionSyncStatus {
  SUCCEEDED
  PARTIAL
  FAILED

  @@map("notion_sync_status")
}

enum ScheduledJobStatus {
  RUNNING
  SUCCEEDED
  FAILED

  @@map("scheduled_job_status")
}

model User {
  id                      String                   @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  email                   String                   @unique
  name                    String
  avatarUrl               String?                  @map("avatar_url")
  preferences             Json                     @default("{}")
  onboardingCompletedAt   DateTime?                @map("onboarding_completed_at") @db.Timestamptz(6)
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                 @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt               DateTime?                @map("deleted_at") @db.Timestamptz(6)
  authAccounts            AuthAccount[]
  ownedOrganizations      Organization[]           @relation("OrganizationOwner")
  memberships             Membership[]
  invitationsSent         Invitation[]             @relation("InvitationInviter")
  editorialContexts       EditorialContext[]       @relation("EditorialContextCreator")
  contentIdeas            ContentIdea[]            @relation("ContentIdeaCreator")
  contentItems            ContentItem[]            @relation("ContentItemCreator")
  aiGenerationLogs        AiGenerationLog[]
  onboardingProgresses    OnboardingProgress[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  qualityEvaluations      AiQualityEvaluation[]      @relation("AiQualityEvaluationCreator")

  @@map("users")
}

model AuthAccount {
  id                String       @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  userId            String       @map("user_id") @db.Uuid
  provider          AuthProvider
  providerAccountId String       @map("provider_account_id")
  passwordHash      String?      @map("password_hash")
  metadata          Json         @default("{}")
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_accounts")
}

model Organization {
  id                      String                   @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  name                    String
  slug                    String                   @unique
  ownerId                 String                   @map("owner_id") @db.Uuid
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                 @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt               DateTime?                @map("deleted_at") @db.Timestamptz(6)
  owner                   User                     @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  memberships             Membership[]
  invitations             Invitation[]
  editorialContexts       EditorialContext[]
  contentIdeas            ContentIdea[]
  contentItems            ContentItem[]
  contentCategories       ContentCategory[]
  tags                    Tag[]
  curatedResources        CuratedResource[]
  sourceFeeds             SourceFeed[]
  resourceTags            ResourceTag[]
  publicationPlans        PublicationPlan[]
  integrationCredentials  IntegrationCredential[]
  aiGenerationLogs        AiGenerationLog[]
  brandVoiceProfile       BrandVoiceProfile?
  onboardingProgresses    OnboardingProgress[]
  automationRules         AutomationRule[]
  reminders               Reminder[]
  recommendations         Recommendation[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  notionDatabaseMapping   NotionDatabaseMapping?
  notionSyncStates        NotionSyncState[]
  notionSyncLogs          NotionSyncLog[]
  auditLogs               OrganizationAuditLog[]
  similarityChecks        SimilarityCheck[]
  qualityEvaluations      AiQualityEvaluation[]

  @@index([ownerId])
  @@map("organizations")
}

model Membership {
  id             String           @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  role           OrganizationRole @default(READER)
  status         MembershipStatus @default(PENDING)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId, status])
  @@index([organizationId, role])
  @@map("memberships")
}

model Invitation {
  id             String           @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  email          String
  role           OrganizationRole @default(READER)
  tokenHash      String           @unique @map("token_hash")
  expiresAt      DateTime         @map("expires_at") @db.Timestamptz(6)
  status         InvitationStatus @default(PENDING)
  invitedById    String?          @map("invited_by_id") @db.Uuid
  acceptedAt     DateTime?        @map("accepted_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy      User?            @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([organizationId, email])
  @@index([organizationId, status])
  @@index([expiresAt])
  @@map("invitations")
}

model EditorialContext {
  id             String       @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  sector         String
  targetAudience String       @map("target_audience")
  tone           String
  positioning    String
  themes         String[]     @default([])
  resourceNotes  String?      @map("resource_notes")
  createdById    String?      @map("created_by_id") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User?        @relation("EditorialContextCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([organizationId])
  @@index([organizationId])
  @@map("editorial_contexts")
}

model ContentIdea {
  id                String            @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  organizationId    String            @map("organization_id") @db.Uuid
  title             String
  angle             String
  recommendedFormat ContentFormat     @map("recommended_format")
  justification     String
  category          String?
  status            ContentIdeaStatus @default(DRAFT)
  createdById       String?           @map("created_by_id") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)
  archivedAt        DateTime?         @map("archived_at") @db.Timestamptz(6)
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy         User?             @relation("ContentIdeaCreator", fields: [createdById], references: [id], onDelete: SetNull)
  contentItems      ContentItem[]
  aiGenerationLogs  AiGenerationLog[] @relation("AiGenerationIdeaResult")

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([organizationId, recommendedFormat])
  @@map("content_ideas")
}

model ContentItem {
  id               String            @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  organizationId   String            @map("organization_id") @db.Uuid
  ideaId           String?           @map("idea_id") @db.Uuid
  categoryId       String?           @map("category_id") @db.Uuid
  title            String
  body             String            @default("")
  format           ContentFormat
  brief            String?
  status           ContentItemStatus @default(DRAFT)
  source           ContentSource     @default(AI_GENERATED)
  topic            String?
  duplicateScore   Float?            @map("duplicate_score")
  createdById      String?           @map("created_by_id") @db.Uuid
  publishedAt      DateTime?         @map("published_at") @db.Timestamptz(6)
  archivedAt       DateTime?         @map("archived_at") @db.Timestamptz(6)
  deletedAt        DateTime?         @map("deleted_at") @db.Timestamptz(6)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  idea             ContentIdea?      @relation(fields: [ideaId], references: [id], onDelete: SetNull)
  category         ContentCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy        User?             @relation("ContentItemCreator", fields: [createdById], references: [id], onDelete: SetNull)
  contentTags      ContentTag[]
  publicationPlans PublicationPlan[]
  aiGenerationLogs AiGenerationLog[] @relation("AiGenerationContentResult")
  qualityEvaluations AiQualityEvaluation[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([organizationId, format])
  @@index([organizationId, source])
  @@index([organizationId, categoryId])
  @@map("content_items")
}

model ContentCategory {
  id             String        @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  name           String
  slug           String
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contentItems   ContentItem[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("content_categories")
}

model Tag {
  id             String        @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  name           String
  slug           String
  color          String?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contentTags    ContentTag[]
  resourceTags   ResourceTag[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("tags")
}

model ContentTag {
  contentItemId  String      @map("content_item_id") @db.Uuid
  tagId          String      @map("tag_id") @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  contentItem    ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  tag            Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentItemId, tagId])
  @@index([organizationId])
  @@index([tagId])
  @@map("content_tags")
}

model CuratedResource {
  id               String            @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  organizationId   String            @map("organization_id") @db.Uuid
  sourceFeedId     String?           @map("source_feed_id") @db.Uuid
  url              String
  title            String
  description      String?
  summary          String?
  keyPoints        String[]          @default([]) @map("key_points")
  source           String?
  sourceName       String?           @map("source_name")
  topic            String?
  type             ResourceType      @default(URL)
  status           ResourceStatus    @default(NEW)
  publishedAt      DateTime?         @map("published_at") @db.Timestamptz(6)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceFeed       SourceFeed?       @relation(fields: [sourceFeedId], references: [id], onDelete: SetNull)
  resourceTags     ResourceTag[]
  aiGenerationLogs AiGenerationLog[] @relation("AiGenerationResourceResult")

  @@unique([organizationId, url])
  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([organizationId, createdAt])
  @@index([organizationId, sourceFeedId])
  @@map("curated_resources")
}

model SourceFeed {
  id             String            @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  url            String
  title          String
  status         SourceFeedStatus  @default(ACTIVE)
  lastFetchedAt  DateTime?         @map("last_fetched_at") @db.Timestamptz(6)
  lastError      String?           @map("last_error")
  nextFetchAt    DateTime?         @map("next_fetch_at") @db.Timestamptz(6)
  failureCount   Int               @default(0) @map("failure_count")
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  resources      CuratedResource[]

  @@unique([organizationId, url])
  @@index([organizationId, status])
  @@index([status, nextFetchAt])
  @@map("source_feeds")
}

model ResourceTag {
  resourceId     String          @map("resource_id") @db.Uuid
  tagId          String          @map("tag_id") @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  resource       CuratedResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  tag            Tag             @relation(fields: [tagId], references: [id], onDelete: Cascade)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([resourceId, tagId])
  @@index([organizationId])
  @@index([tagId])
  @@map("resource_tags")
}

model BrandVoiceProfile {
  id             String       @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  organizationId String       @unique @map("organization_id") @db.Uuid
  language       String       @default("fr")
  toneRules      String       @default("") @map("tone_rules")
  examples       String[]     @default([])
  forbiddenTerms String[]     @default([]) @map("forbidden_terms")
  creativity     Int          @default(2)
  targetLength   String       @default("standard") @map("target_length")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("brand_voice_profiles")
}

model PublicationPlan {
  id              String             @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  organizationId  String             @map("organization_id") @db.Uuid
  contentItemId   String             @map("content_item_id") @db.Uuid
  channel         PublicationChannel
  publicationDate DateTime           @map("publication_date") @db.Timestamptz(6)
  status          PublicationStatus  @default(DRAFT)
  notes           String?
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contentItem     ContentItem        @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  reminders       Reminder[]

  @@index([organizationId, publicationDate])
  @@index([organizationId, status])
  @@index([organizationId, channel])
  @@map("publication_plans")
}

model OnboardingProgress {
  id             String       @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  currentStep    String       @default("CHECKLIST") @map("current_step")
  completedSteps String[]     @default([]) @map("completed_steps")
  skippedAt      DateTime?    @map("skipped_at") @db.Timestamptz(6)
  completedAt    DateTime?    @map("completed_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("onboarding_progress")
}

model AutomationRule {
  id             String               @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  type           AutomationRuleType
  status         AutomationRuleStatus @default(ACTIVE)
  parameters     Json                 @default("{}")
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type])
  @@index([organizationId, status])
  @@map("automation_rules")
}

model Reminder {
  id                String          @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  organizationId    String          @map("organization_id") @db.Uuid
  publicationPlanId String          @map("publication_plan_id") @db.Uuid
  triggerAt         DateTime        @map("trigger_at") @db.Timestamptz(6)
  status            ReminderStatus  @default(PENDING)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  publicationPlan   PublicationPlan @relation(fields: [publicationPlanId], references: [id], onDelete: Cascade)
  notifications     Notification[]

  @@unique([organizationId, publicationPlanId, triggerAt])
  @@index([organizationId, status])
  @@index([triggerAt])
  @@map("reminders")
}

model Recommendation {
  id             String               @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  type           String
  message        String
  targetType     String?              @map("target_type")
  targetId       String?              @map("target_id") @db.Uuid
  status         RecommendationStatus @default(OPEN)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([organizationId, type])
  @@unique([organizationId, type, targetType, targetId])
  @@map("recommendations")
}

model Notification {
  id             String             @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  userId         String             @map("user_id") @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  reminderId     String?            @map("reminder_id") @db.Uuid
  title          String
  body           String
  status         NotificationStatus @default(UNREAD)
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  readAt         DateTime?          @map("read_at") @db.Timestamptz(6)
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reminder       Reminder?          @relation(fields: [reminderId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([organizationId, createdAt])
  @@unique([userId, reminderId])
  @@map("notifications")
}

model NotificationPreference {
  id             String       @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  inAppEnabled   Boolean      @default(true) @map("in_app_enabled")
  emailEnabled   Boolean      @default(false) @map("email_enabled")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("notification_preferences")
}

model IntegrationCredential {
  id                String              @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  organizationId    String              @map("organization_id") @db.Uuid
  provider          IntegrationProvider
  encryptedMetadata String              @map("encrypted_metadata")
  encryptionKeyRef  String?             @map("encryption_key_ref")
  status            IntegrationStatus   @default(ACTIVE)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @default(now()) @map("updated_at") @db.Timestamptz(6)
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@index([organizationId, status])
  @@map("integration_credentials")
}

