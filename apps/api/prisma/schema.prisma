model AiGenerationLog {
  id                  String             @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  organizationId      String             @map("organization_id") @db.Uuid
  userId              String?            @map("user_id") @db.Uuid
  type                AiGenerationType
  promptVersion       String             @default("legacy") @map("prompt_version")
  inputHash           String             @default("unknown") @map("input_hash")
  promptMetadata      Json               @default("{}") @map("prompt_metadata")
  model               String
  estimatedCostCents  Int?               @map("estimated_cost_cents")
  status              AiGenerationStatus @default(SUCCEEDED)
  resultId            String?            @map("result_id") @db.Uuid
  resultContentIdeaId String?            @map("result_content_idea_id") @db.Uuid
  resultContentItemId String?            @map("result_content_item_id") @db.Uuid
  resultResourceId    String?            @map("result_resource_id") @db.Uuid
  errorCode           String?            @map("error_code")
  errorMessage        String?            @map("error_message")
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  resultContentIdea   ContentIdea?       @relation("AiGenerationIdeaResult", fields: [resultContentIdeaId], references: [id], onDelete: SetNull)
  resultContentItem   ContentItem?       @relation("AiGenerationContentResult", fields: [resultContentItemId], references: [id], onDelete: SetNull)
  resultResource      CuratedResource?   @relation("AiGenerationResourceResult", fields: [resultResourceId], references: [id], onDelete: SetNull)

  @@index([organizationId, type])
  @@index([organizationId, inputHash])
  @@index([organizationId, createdAt])
  @@index([organizationId, model])
  @@index([userId])
  @@index([resultContentIdeaId])
  @@index([resultContentItemId])
  @@index([resultResourceId])
  @@index([promptVersion])
  @@map("ai_generation_logs")
}
